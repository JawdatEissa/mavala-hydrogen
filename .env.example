# =============================================================================
# Mavala Hydrogen — Environment Variables Template
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any file containing real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Shopify Admin API — Client Credentials (NEW as of Jan 2026)
#
# There is NO static token in the UI anymore. Instead, your server exchanges
# Client ID + Client Secret for a short-lived token (24h) at runtime via:
#   POST https://{store}.myshopify.com/admin/oauth/access_token
#
# How to get these:
#   1. Go to https://dev.shopify.com/dashboard (the Dev Dashboard)
#   2. Open your app → Settings
#   3. Copy "Client ID" (hex string — also called "Default API Key" in some views)
#   4. Copy "Client secret" (starts with shpss_...)
#
# Required Admin API scopes (set in Dev Dashboard → app → Configuration):
#   read_products, write_products, read_collections, write_collections,
#   read_orders, read_customers, write_customers (quiz profile metafields), read_inventory
# -----------------------------------------------------------------------------
SHOPIFY_CLIENT_ID=your-hex-client-id-here
SHOPIFY_CLIENT_SECRET=shpss_your-client-secret-here
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_API_VERSION=2025-01

# -----------------------------------------------------------------------------
# Shopify Storefront API — Static token (still available for public storefront)
#
# This token is scoped and safe for server-side use. It does NOT expire.
# How to get:
#   Option A (Headless channel — recommended):
#     Shopify Admin → Sales channels → Headless → Add Storefront
#     → Copy the "Public" and "Private" tokens shown
#   Option B (via your Dev Dashboard app):
#     Dev Dashboard → your app → Configuration → Storefront API access
#
# Cart / checkout (Phase 2): grant unauthenticated Storefront scopes on the token:
#   unauthenticated_read_checkouts, unauthenticated_write_checkouts
# Customer signup / login (Storefront customer mutations):
#   unauthenticated_read_customers, unauthenticated_write_customers
# See: https://shopify.dev/docs/api/usage/access-scopes#unauthenticated-access-scopes
# -----------------------------------------------------------------------------
PUBLIC_STOREFRONT_API_TOKEN=your-public-storefront-token-here
PRIVATE_STOREFRONT_API_TOKEN=your-private-storefront-token-here
PUBLIC_STORE_DOMAIN=your-store.myshopify.com
PUBLIC_STOREFRONT_API_VERSION=2025-01

# -----------------------------------------------------------------------------
# Shopify Customer Account API (for customer login / account pages)
# How to get: Shopify Admin → Settings → Customer accounts → API credentials
# -----------------------------------------------------------------------------
PUBLIC_CUSTOMER_ACCOUNT_API_CLIENT_ID=your-customer-account-client-id
PUBLIC_CUSTOMER_ACCOUNT_API_URL=https://shopify.com/your-shop-id/account

# -----------------------------------------------------------------------------
# App session / signed cookies (anonymous chat turn limit)
# -----------------------------------------------------------------------------
# Used to sign the httpOnly mavala_chat_anon_uses cookie. Set a long random string
# in production (e.g. openssl rand -hex 32).
SESSION_SECRET=change-me-in-production-use-long-random-string

# -----------------------------------------------------------------------------
# Optional: treat all requests as logged-in (local QA only — never in production)
# -----------------------------------------------------------------------------
# MAVALA_AUTH_DEV_BYPASS=true

# -----------------------------------------------------------------------------
# OpenAI (AI chatbot — already working)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-proj-...

# -----------------------------------------------------------------------------
# Supabase (AI chatbot vector store — already working)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE=your-service-role-key-here

# -----------------------------------------------------------------------------
# Vercel (auto-injected by Vercel CLI — do not set manually)
# -----------------------------------------------------------------------------
# VERCEL_OIDC_TOKEN=auto-injected
