    "start": "remix-serve ./build/server/index.js",
    "lint": "eslint --ext .js,.jsx,.ts,.tsx .",
    "ingest": "npx tsx scripts/ingest-content.ts",
    "ingest:clear": "npx tsx scripts/ingest-content.ts --clear"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@remix-run/node": "^2.12.1",
