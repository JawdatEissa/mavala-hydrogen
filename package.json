    "@remix-run/serve": "^2.12.1",
    "@supabase/supabase-js": "^2.93.3",
    "@vercel/remix": "^2.16.7",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.23.26",
    "isbot": "^5.1.0",
    "openai": "^6.17.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@remix-run/dev": "^2.12.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.3",
