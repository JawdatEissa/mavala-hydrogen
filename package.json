{
  "name": "mavala-hydrogen",
  "version": "1.0.0",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "prebuild": "node scripts/generate-image-manifest.mjs",
    "optimize:diagnosis-icons": "node scripts/optimize-diagnosis-icons.mjs",
    "build": "npx remix vite:build",
